{
  "manifest_version": 3,
  "name": "Model Judge MVP",
  "version": "0.2.0",
  "description": "Tab-based model comparison MVP using already open provider tabs.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://www.claude.ai/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*"
  ],
  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Open Model Judge"
  },
  "icons": {
    "16": "src/icons/icon-16.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  }
}
